public class KPMGCommon_KaytekIntegrationController extends SysOperationServiceController
{
    protected void new()
    {
        super(
            classStr(KPMGCommon_KaytekIntegrationService),
            methodStr(KPMGCommon_KaytekIntegrationService, process),
            SysOperationExecutionMode::Synchronous);
    }

    public static KPMGCommon_KaytekIntegrationController construct(SysOperationExecutionMode _executionMode = SysOperationExecutionMode::Synchronous)
    {
        KPMGCommon_KaytekIntegrationController controller = new KPMGCommon_KaytekIntegrationController();
        controller.parmExecutionMode(_executionMode);
        return controller;
    }

    public static void main(Args _args)
    {
        KPMGCommon_KaytekIntegrationController controller = KPMGCommon_KaytekIntegrationController::construct();
        controller.parmArgs(_args);
        controller.startOperation();
    }

}