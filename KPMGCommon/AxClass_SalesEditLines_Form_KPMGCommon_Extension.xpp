[ExtensionOf(formStr(SalesEditLines))]
final class SalesEditLines_Form_KPMGCommon_Extension
{
    public NoYes           _PrintFormLetterPackingList,
                           _PrintFormLetterWayBill;
    
    public SalesEditLinesForm KPMGCommon_getSalesEditLinesForm()
    {
        return salesEditLinesForm;
    }

    void  run()
    {

        next run();

        if (salesParmUpdate.ParmId)
        {
            switch (documentStatus)
            {
                case DocumentStatus::PackingSlip:
                    KPMGCommon_PrintFormLetterPackingList.visible(true);
                    KPMGCommon_PrintFormLetterPackingList.label("@KPMGCommon:PackingListPrint"); // Imprimir PackingList
                    
                    KPMGCommon_PrintFormLetterWayBill.visible(true);
                    KPMGCommon_PrintFormLetterWayBill.label("@KPMGCommon:PrintWayBill"); //// Imprimir carta de porte

                    KPMGCommon_PrintDeclarationOfConformityCert.visible(true);
                    KPMGCommon_PrintDeclarationOfConformityCert.label("@KPMGCommon:PrintDeclarationOfConformity"); // Imprimir declaración de conformidad

                    KPMGCommon_GroupProductLines.visible(true);
                    KPMGCommon_GroupProductLines.label("@KPMGCommon:GroupProductLines");
                    
                    KPMGCommon_PrintFormLetterPackingList.value(salesFormLetter.KPMGCommon_PrintFormLetterPackingList());
                    KPMGCommon_PrintFormLetterWayBill.value(salesFormLetter.KPMGCommon_PrintFormLetterWayBill());
                    KPMGCommon_PrintDeclarationOfConformityCert.value(salesFormLetter.KPMGCommon_PrintDeclarationOfConformityCert());
                    KPMGCommon_GroupProductLines.value(salesFormLetter.KPMGCommon_GroupProductLines());
                    

                    break;
                default:
                    KPMGCommon_PrintFormLetterPackingList.visible(false);
                    KPMGCommon_PrintFormLetterPackingList.label('');
                    
                    KPMGCommon_PrintFormLetterWayBill.visible(false);
                    KPMGCommon_PrintFormLetterWayBill.label('');

                    KPMGCommon_PrintDeclarationOfConformityCert.visible(false);
                    KPMGCommon_PrintDeclarationOfConformityCert.label(' ');

                    KPMGCommon_GroupProductLines.visible(false);
                    KPMGCommon_GroupProductLines.label(' ');

                    KPMGCommon_PrintFormLetterPackingList.value(NoYes::No);
                    KPMGCommon_PrintFormLetterWayBill.value(NoYes::No);
                    KPMGCommon_PrintDeclarationOfConformityCert.value(NoYes::No);
                    KPMGCommon_GroupProductLines.value(NoYes::No);
                    break;
            }
       }
    }

    public void updateDesign_MX()
    {
        next updateDesign_MX();

        if (EInvoiceCFDIParameters_MX::isElectronicInvoiceEnabled() && !salesFormLetter.proforma())
        {
            switch (documentStatus)
            {
                case DocumentStatus::Invoice:
                case DocumentStatus::FreeTextInvoice:
                case DocumentStatus::PackingSlip:
                    KPMGCommon_PrintFormLetterPackingList.value(false);
                    KPMGCommon_PrintFormLetterPackingList.enabled(false);
                    KPMGCommon_PrintFormLetterWayBill.value(false);
                    KPMGCommon_PrintFormLetterWayBill.enabled(false);
                    KPMGCommon_PrintDeclarationOfConformityCert.value(false);
                    KPMGCommon_PrintDeclarationOfConformityCert.enabled(false);
                    break;
            }
        }
    }

    /// <summary>
    /// Initialize an instance of <c>SalesFormLetter</c>.
    /// </summary>
    protected void initializeSalesFormLetter()
    {
        next initializeSalesFormLetter();
 
       salesFormLetter.KPMGCommon_initParameter_KPMGCommon_PrintFormLetterPackingList(
            KPMGCommon_PrintFormLetterPackingList.value());
        
        salesFormLetter.KPMGCommon_initParameter_KPMGCommon_PrintFormLetterWayBill(
            KPMGCommon_PrintFormLetterWayBill.value());

        salesFormLetter.KPMGCommon_initParameter_KPMGCommon_PrintDeclarationOfConformityCert(
            KPMGCommon_PrintDeclarationOfConformityCert.value());
    }

    boolean reArrange()
    {
        boolean  ok = true;
        
        salesFormLetter.KPMGCommon_initParameter_KPMGCommon_PrintFormLetterPackingList(
            KPMGCommon_PrintFormLetterPackingList.value());

        salesFormLetter.KPMGCommon_initParameter_KPMGCommon_PrintFormLetterWayBill(
            KPMGCommon_PrintFormLetterWayBill.value());

        salesFormLetter.KPMGCommon_initParameter_KPMGCommon_PrintDeclarationOfConformityCert(
            KPMGCommon_PrintDeclarationOfConformityCert.value());

        ok = next reArrange();
        return ok;
    }

}