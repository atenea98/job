[ExtensionOf(classStr(FormLetterContract))]
final class FormLetterContract_KPMGCommon_Extension
{
    public NoYes           KPMGCommon_PrintFormLetterPackingList,
                           KPMGCommon_PrintFormLetterWayBill, KPMGCommon_PrintDeclarationOfConformityCert, KPMGCommon_GroupProductLines;
    #define.CurrentVersion(1)
    #LOCALMACRO.CurrentList
        KPMGCommon_PrintFormLetterPackingList
        ,KPMGCommon_PrintFormLetterWayBill
        ,KPMGCommon_PrintDeclarationOfConformityCert
        ,KPMGCommon_GroupProductLines
    #ENDMACRO


    public container pack()
    {

        container packedClass = next pack();
        return SysPackExtensions::appendExtension(packedClass, classStr(FormLetterContract_KPMGCommon_Extension), this.myPack());
    }

    private boolean myUnpack(container packedClass)
    {
        Integer version = RunBase::getVersion(packedClass);
        switch (version)
        {
            case #CurrentVersion:
                [version, #CurrentList] = packedClass;
                break;
            default:
                return false;
        }
        return true;
    }

    private container myPack()
    {
        return [#CurrentVersion, #CurrentList];
    }

    public boolean unpack(container _packedClass)
    {
        boolean result = next unpack(_packedClass);

        if (result)
        {
            container axmState = SysPackExtensions::findExtension(_packedClass, classStr(FormLetterContract_KPMGCommon_Extension));
            //Also unpack the extension
            if (!this.myUnpack(axmState))
            {
                result = false;
            }
        }

        return result;
    }

    [DataMember]
    public NoYes KPMGCommon_parmPrintFormLetterPackingList(NoYes _KPMGCommon_PrintFormLetterPackingList = KPMGCommon_PrintFormLetterPackingList)
    {
        KPMGCommon_PrintFormLetterPackingList = _KPMGCommon_PrintFormLetterPackingList;
        return KPMGCommon_PrintFormLetterPackingList;
    }

    [DataMember]
    public NoYes KPMGCommon_parmPrintFormLetterWayBill(NoYes _KPMGCommon_PrintFormLetterWayBill = KPMGCommon_PrintFormLetterWayBill)
    {
        KPMGCommon_PrintFormLetterWayBill = _KPMGCommon_PrintFormLetterWayBill;
        return KPMGCommon_PrintFormLetterWayBill;
    }

    [DataMember]
    public NoYes KPMGCommon_parmPrintDeclarationOfConformityCert(NoYes _KPMGCommon_PrintDeclarationOfConformityCert = KPMGCommon_PrintDeclarationOfConformityCert)
    {
        KPMGCommon_PrintDeclarationOfConformityCert = _KPMGCommon_PrintDeclarationOfConformityCert;
        return KPMGCommon_PrintDeclarationOfConformityCert;
    }

    [DataMember]
    public NoYes KPMGCommon_parmGroupProductLines(NoYes _KPMGCommon_GroupProductLines = KPMGCommon_GroupProductLines)
    {
        KPMGCommon_GroupProductLines = _KPMGCommon_GroupProductLines;
        return KPMGCommon_GroupProductLines;
    }

}