        this.mapDataSourceFieldToEntityField(_inventTable, fieldnum(InventTable, KPFOriginalCreatedDate), _kPFInventTableOriginalCreatedDateEntity, fieldnum(KPFInventTableOriginalCreatedDateEntity, OriginalCreatedDate), false);
        this.mapFromDataSourceExtensions(_dataSourceCtx, _inventTable, _kPFInventTableOriginalCreatedDateEntity);
        // map system fields (e.g. recid and recversion) from data source buffer to view record.
        _kPFInventTableOriginalCreatedDateEntity.fromViewDataSource(_dataSourceCtx.id(), _inventTable);
    }
