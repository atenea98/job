            this.mapEntityFieldToDataSourceField(_dataSourceCtx.getDatabaseOperation(), _kPFInventTableOriginalCreatedDateEntity, fieldnum(KPFInventTableOriginalCreatedDateEntity, ItemId), _inventTable, fieldnum(InventTable, ItemId), 1);
            this.mapEntityFieldToDataSourceField(_dataSourceCtx.getDatabaseOperation(), _kPFInventTableOriginalCreatedDateEntity, fieldnum(KPFInventTableOriginalCreatedDateEntity, OriginalCreatedDate), _inventTable, fieldnum(InventTable, KPFOriginalCreatedDate), 1);
            
            this.mapToDataSourceExtensions(_dataSourceCtx, _inventTable, _kPFInventTableOriginalCreatedDateEntity);
            _inventTable.trackFieldExternallySet(false);
        }
    }
