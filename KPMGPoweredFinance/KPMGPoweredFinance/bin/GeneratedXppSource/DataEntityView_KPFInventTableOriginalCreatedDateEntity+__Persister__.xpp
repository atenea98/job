    private InventTable LookForUniqueKeyMatch_DS1(KPFInventTableOriginalCreatedDateEntity _kPFInventTableOriginalCreatedDateEntity, InventTable _inventTable)
    {
        InventTable inventTable_ = null;
        
        select
            forUpdate
            firstOnly
                inventTable_
        where
            inventTable_.ItemId == _inventTable.ItemId
        ;
        
        if (inventTable_)
        {
            return inventTable_;
        }
        
        select
            forUpdate
            firstOnly
                inventTable_
        where
            inventTable_.Product == _inventTable.Product && inventTable_.DataAreaId == _inventTable.DataAreaId
        ;
        
        if (inventTable_)
        {
            return inventTable_;
        }
        
        return inventTable_;
    }

