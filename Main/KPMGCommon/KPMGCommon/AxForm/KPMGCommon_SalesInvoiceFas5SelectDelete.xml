		<DataControls xmlns="">
			<Control>
				<Name>KPMGCommon_DeleteFas5Record</Name>
				<Type>Button</Type>
				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void clicked()
        {
            if (Box::okCancel("¿Estás seguro de que quieres eliminar esta factura?", DialogButton::Yes) == DialogButton::Ok)
            {
                super();
                KPMGCommon_SalesInvoiceFas5 _salesInvoiceFas5;
                KPMGCommon_SalesInvoiceFas5 salesInvoiceFas5;
                KPMGCommon_SalesInvoiceFas5 salesInvoiceToDelete;
                FormDataSource      salesInvoiceFas5_ds;
                FormRun             formRun;

                formRun = this.formRun();
                salesInvoiceFas5_ds = formRun.dataSource("KPMGCommon_SalesInvoiceFas5");
                salesInvoiceToDelete = salesInvoiceFas5_ds.cursor();

                while select forupdate _salesInvoiceFas5 where _salesInvoiceFas5.InvoiceId == salesInvoiceToDelete.InvoiceId
                {
                    ttsbegin;
                    if (!_salesInvoiceFas5.Treated && _salesInvoiceFas5.DiarioId == '')
                    {
                        KPMGCommon_SalesInvoiceFas5Delete salesInvoiceFas5Delete;
                        KPMGCommon_SalesInvoiceFas5Error salesInvoiceFas5Error;

                        //Crear registro en tabla de eliminados
                        insert_recordset salesInvoiceFas5Delete
                    (InvoiceYear, NumLine, NumFact5, InvoiceId, InvoiceDate, TipoVenta, DescTV,
                    CContable, CustomerId, Cif, CustomerName, FVencimiento, TaxGroup, ItemTaxGroup,
                    TotalInvoice, NetAmount, IVA, CuotaIVA, PlasticNetAmount, PlasticIVA, CuotaPlasticIVA,
                    Error, Treated, DiarioId, PaymentMode)
                select
                    InvoiceYear, NumLine, NumFact5, InvoiceId, InvoiceDate, TipoVenta, DescTV,
                    CContable, CustomerId, Cif, CustomerName, FVencimiento, TaxGroup, ItemTaxGroup,
                    TotalInvoice, NetAmount, IVA, CuotaIVA, PlasticNetAmount, PlasticIVA, CuotaPlasticIVA,
                    Error, Treated, DiarioId, PaymentMode from salesInvoiceFas5
                    where salesInvoiceFas5.RecId == _salesInvoiceFas5.RecId;
                        //Borrar registro
                        while select forupdate salesInvoiceFas5Error where salesInvoiceFas5Error.RefRecId == _salesInvoiceFas5.RecId
                        {
                            salesInvoiceFas5Error.delete();
                        }
                        _salesInvoiceFas5.delete();
                    }
                    ttscommit;
                }
                KPMGCommon_SalesInvoiceFas5_ds.reread();
            }
        }

]]></Source>
