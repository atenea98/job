				<Source><![CDATA[
[Form]

public class JmgProductionFloorExecutionWMSLocationLookup extends FormRun
{   
    private FormRun         parentForm;
    private ProdId          prodId;
    private ItemId          itemId;
    private InventTransId   inventTransId;
    private str             WMSLocationValue;
    private boolean         newBusinessCardFlightEnabled;

}
]]></Source>
			</Method>
			<Method>
				<Name>run</Name>
				<Source><![CDATA[
    [Hookable(false)]
    public void run()
    {
        super();

        // To opt out a page from the new grid
        this.forceLegacyGrid();
    }

]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    [Hookable(false)]
    public void init()
    {
        super();
        if (element.args())
        {
            parentForm = element.args().caller() as JmgProductionFloorExecutionITrackingDimensions;
        }
        else
        {
            throw error(Error::wrongUseOfFunction(funcName()));
        }

        newBusinessCardFlightEnabled = KPMGCommon_JmgProductionFloorExecutionNewBusinessCardFlight::instance().isEnabled();
        CardGroup.enabled(!newBusinessCardFlightEnabled);

        if (KPMGCommon_JmgProductionFloorExecutionNewBusinessCardFlight::instance().isEnabled())
        {
            CardGroup.allowEdit(false);
            CardGroup.enabled(true);
        }

        ContentSection.visible(false);
        ContentSectionLongTilesGroup.visible(true);
        FooterGroupLongTiles.visible(true);
		SearchFilterControl.setFocus();
        
        if (!prodId || !itemId)
        {
            str errorMessage = strFmt("@SYS50104", !prodId ? "ProdId" : !itemId? "@ENG185" : "");
            KPMGCommon_JmgProductionFloorExecutionInfoMessage infoMessage = new KPMGCommon_JmgProductionFloorExecutionInfoMessage(null, errorMessage, false);
            infoMessage.parmCancelButtonVisible(true);
            infoMessage.openErrorDialog();
        }
    }

]]></Source>
