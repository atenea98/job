						<Name>init</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        [Hookable(false)]
        public void init()
        {
            InventLocationId inventLocationId = ProdTable::find(prodId).inventDim().InventLocationId;
            InventTable      inventTable = InventTable::find(itemId);
            
            super();

            QueryBuildDataSource queryBuildWMSLocationDataSource = WMSLocation_DS.query().dataSourceTable(tableNum(WMSLocation));
            queryBuildWMSLocationDataSource.clearDynalinks();
            queryBuildWMSLocationDataSource.addRange(fieldNum(WMSLocation, InventLocationId)).value(inventLocationId);
            queryBuildWMSLocationDataSource.addRange(fieldNum(WMSLocation, WMSLocationId)).value(SysQuery::valueNotEmptyString());
            queryBuildWMSLocationDataSource.addRange(fieldNum(WMSLocation, LocProfileId)).value(inventTable.KPMGCommon_LocProfileId);
        }

]]></Source>
